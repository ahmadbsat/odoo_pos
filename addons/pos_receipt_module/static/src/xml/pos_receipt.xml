<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_receipt_module.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <!-- Add custom header before the receipt -->
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-set-slot="before-receipt">
                <div class="custom-receipt-header" style="text-align: center; margin-bottom: 15px;">
                    <div style="font-size: 28px; font-weight: bold;">
                        <t t-esc="props.data.company.name"/>
                    </div>
                    <div style="font-size: 20px; margin-top: 5px;">
                        Ahmad Bsat
                    </div>
                </div>
            </t>
        </xpath>
        <!-- Make order number bigger -->
        <xpath expr="//div[hasclass('order-number')]" position="attributes">
            <attribute name="style">font-size: 56px; font-weight: bold;</attribute>
        </xpath>
    </t>
</templates>
